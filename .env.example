# Escolha um provedor:
# gmail | outlook | hotmail | yahoo | icloud | hostinger | uol | bol | custom
EMAIL_PROVIDER=gmail

# Para provedores conhecidos, o host e a porta podem ficar vazios.
# Para custom, preencha manualmente SMTP_HOST e SMTP_PORT.
SMTP_HOST=
SMTP_PORT=

SMTP_USER=seuemail@empresa.com
SMTP_PASSWORD=sua_senha_ou_token
SMTP_FROM=seuemail@empresa.com

# Quando quiser integrar SMS no futuro:
# SMS_ENABLED=false
